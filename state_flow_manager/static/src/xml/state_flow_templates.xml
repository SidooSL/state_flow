<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Template for the new StateFlowManagerContainer -->
    <t t-name="state_flow_manager.StateFlowManagerContainer" owl="1">
        <div class="o_state_flow_manager_container card w-100 mb-3 mx-0" t-if="props.record and props.record.data">
            <div class="card-body p-0 container-fluid">
                <div class="container-fluid px-3 py-2">
                    <div t-if="state.isLoading" class="text-center">
                        <i class="fa fa-spinner fa-spin"/> Loading State Flow...
                    </div>
                    <div t-else="">
                        <div class="d-flex flex-row align-items-center mb-3 px-0">
                            <div class="process-info">
                                <h4 class="mb-0">
                                    <strong class="text-primary">Process:</strong>
                                    <span t-esc="state.processName" class="ms-2 fs-4"/>
                                </h4>
                            </div>
                            <div class="state-info ms-auto">
                                <h4 class="mb-0">
                                    <strong class="text-primary">State:</strong>
                                    <span class="ms-2 fs-4">
                                        <i t-if="state.currentStateIcon" t-att-class="state.currentStateIcon"></i>
                                        <t t-esc="state.currentStateName"/>
                                        <a t-if="state.currentStateId" t-att-href="'/state_flow/state_info/' + state.currentStateId" class="ms-2 text-info" title="State Info" target="_blank">
                                            <i class="fa fa-info-circle"></i>
                                        </a>
                                    </span>
                                </h4>
                            </div>
                        </div>

                        <div t-if="props.record.data.available_transition_ids.records.length > 0">
                            <div class="d-flex flex-column flex-md-row gap-2 w-100">
                                <t t-foreach="props.record.data.available_transition_ids.records" t-as="transition" t-key="transition.data.id">
                                    <button type="button" 
                                            class="btn btn-sm btn-primary w-100 w-md-auto"
                                            t-on-click="() => this.executeTransition(transition.resId)">
                                        <t t-esc="(transition.data.name || transition.data.display_name || 'Unnamed')"/>
                                    </button>
                                </t>
                            </div>
                        </div>
                        <div t-else="">
                            <p class="text-muted fst-italic">No transitions available from the current state.</p>
                        </div>

                    </div>
                </div>
            </div>
        </div>
        <div class="alert alert-warning" t-if="!props.record or !props.record.data">
            State Flow Manager: Record data not available.
        </div>
    </t>

    <!-- Template for the State Flow Diagram -->
    <t t-name="state_flow_manager.StateFlowDiagram">
        <div class="state_flow_diagram_container">
            <div t-if="state.isLoading" class="text-center p-4">
                <i class="fa fa-spinner fa-spin fa-2x text-muted"></i>
                <p class="mt-2 text-muted">Loading diagram...</p>
                </div>
            <div t-ref="diagramContainer" class="mermaid-diagram-container" 
                 style="min-height: 400px; border: 1px solid #ddd; border-radius: 4px; padding: 10px; background: white;">
                <!-- Mermaid diagram will be rendered here -->
            </div>
        </div>
    </t>

</templates>