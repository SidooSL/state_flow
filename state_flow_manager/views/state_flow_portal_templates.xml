    <template id="portal_layout_inherit_state_flow" name="Portal Layout: State Flow" inherit_id="portal.portal_layout">
        <xpath expr="//div[@id='wrap']/div[1]" position="before">
            <!-- This will try to inject the state flow interface at the beginning of #wrapwrap or main -->
            <t t-if="object and 'process_id' in object._fields and object.process_id and object.current_state_id">
                <div class="container o_portal_state_flow_details mt-4 mb-4 p-3 border rounded">
                    <h4><t t-if="object.process_id" t-out="object.process_id.name"/> - Status</h4>
                    <p class="lead">
                        Current State: 
                        <span>
                            <i t-if="object.current_state_id.icon_class" t-attf-class="fa #{object.current_state_id.icon_class}" role="img" t-att-aria-label="object.current_state_id.name" t-att-title="object.current_state_id.name"></i>
                            <t t-out="object.current_state_id.name"/>
                        </span>
                    </p>
