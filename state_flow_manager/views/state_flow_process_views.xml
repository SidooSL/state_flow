<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_state_flown_process_form" model="ir.ui.view">
        <field name="name">state_flow.process.form</field>
        <field name="model">state.flow.process</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="model_id"/>
                        <field name="domain"/>
                    </group>
                    <notebook>
                        <page string="States">
                            <field name="state_ids" foce_save="1">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                        <page string="Transitions">
                            <field name="transition_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="from_state_id"/>
                                    <field name="to_state_id"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="sequence"/>
                                        <field name="from_state_id"/>
                                        <field name="to_state_id"/>
                                    </group>
                                    <group>
                                        <field name="model_name" invisible="1" force_save="True"/>
                                        <field name="model_id" options="{'no_create': True}"/>
                                        <field name="server_action_id"/>
                                        <field name="domain" widget="domain" options="{'model': 'model_name', 'in_dialog': True}"/>
                                        <field name="domain_fail_message"/>
                                        
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_state_flown_process_tree" model="ir.ui.view">
        <field name="name">state_flow.process.tree</field>
        <field name="model">state.flow.process</field>
        <field name="arch" type="xml">
            <list string="State FlowN Processes">
                <field name="name"/>
            </list>
        </field>
    </record>


    <record id="action_state_flow_process" model="ir.actions.act_window">
        <field name="name">State Flow Processes</field>
        <field name="res_model">state.flow.process</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_state_flow_process_manager" name="State Flow Process Manager" sequence="10"/>
    <menuitem id="menu_state_flown_processes" name="Processes" parent="menu_state_flow_process_manager" action="action_state_flow_process" sequence="10"/>
</odoo>