<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_state_flow" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.state_flow</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <sheet position="before">
                <group col="4" string="State Flow">
                <group>
                    <field name="available_process_ids" invisible="1"/>
                    <field name="process_id" />
                    <field name="current_state_id" />
                </group>
                <group>
                    <field name="available_transition_ids"  invisible="1"/>
                    <field name="selected_transition_id" widget="selection"/>
                    <button string="Execute"
                        name="execute_transition"
                        type="object"/>
                </group>
                </group>
            </sheet>
        </field>
    </record>
</odoo>