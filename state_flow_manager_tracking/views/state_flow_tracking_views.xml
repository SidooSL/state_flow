<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_state_flow_tracking_list" model="ir.ui.view">
        <field name="name">state.flow.tracking.list</field>
        <field name="model">state.flow.tracking</field>
        <field name="arch" type="xml">
            <list string="State Flow Tracking" create="0" edit="0">
                <field name="res_model"/>
                <field name="res_id"/>
                <field name="state_id"/>
                <field name="start"/>
                <field name="end"/>
                <field name="duration_display"/>
            </list>
        </field>
    </record>

    <record id="view_state_flow_tracking_form" model="ir.ui.view">
        <field name="name">state.flow.tracking.form</field>
        <field name="model">state.flow.tracking</field>
        <field name="arch" type="xml">
            <form string="State Flow Tracking" create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="state_id"/>
                        </group>
                        <group>
                            <field name="start"/>
                            <field name="end"/>
                            <field name="duration_display"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_state_flow_tracking" model="ir.actions.act_window">
        <field name="name">State Flow Tracking</field>
        <field name="res_model">state.flow.tracking</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_state_flow_tracking" 
              name="Tracking" 
              parent="state_flow_manager.menu_state_flow_process_manager" 
              action="action_state_flow_tracking" 
              sequence="20"/>
</odoo>
