<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_inherit_state_flow" model="ir.ui.view">
        <field name="name">project.project.form.inherit.state.flow</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet" position="before">
                
                <!-- State Flow Manager Container -->
                <!-- This field `id` is just a carrier for the widget. The widget uses props.record -->
                <field name="id" widget="state_flow_manager_container" nolabel="1" readonly="1"/>
                
                <!-- Ensure necessary fields for the widget are available, even if invisible -->
                <field name="process_id" invisible="1"/>
                <field name="current_state_id" invisible="1"/>
                <field name="available_transition_ids" invisible="1"/>
            </xpath>
        </field>
    </record>

        <!-- Current state column -->
    <record id="view_project_add_state_flow" model="ir.ui.view">
        <field name="name">project.project.list.inherit.state</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="current_state_id" string="Current state" optional="show"/>
            </xpath>
        </field>
    </record>
    
</odoo> 